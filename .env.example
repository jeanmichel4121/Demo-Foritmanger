# FortiManager Connection Settings
# Copy this file to .env and fill in your values

# =============================================================================
# CONNECTION
# =============================================================================
FMG_HOST=192.168.1.100
FMG_PORT=443

# =============================================================================
# AUTHENTICATION
# Choose ONE of the two methods:
# =============================================================================

# Method 1: Session-based (login/logout)
FMG_USERNAME=api_admin
FMG_PASSWORD=your_password_here

# Method 2: API Key / Bearer Token (recommended for FMG 7.2.2+)
# FMG_API_KEY=your_api_key_here

# =============================================================================
# ADOM CONFIGURATION
# =============================================================================
FMG_ADOM=root

# =============================================================================
# OPTIONS
# =============================================================================
# Disable SSL verification (lab only!)
FMG_VERIFY_SSL=false

# Debug mode (shows requests/responses)
FMG_DEBUG=false
